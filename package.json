{
  "name": "sispat-sistema-patrimonial",
  "version": "0.0.193",
  "description": "Sistema de Gestão Patrimonial",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon server/index.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=src --testPathPattern=server --testNamePattern='unit|spec'",
    "test:integration": "jest --testPathPattern=src --testPathPattern=server --testNamePattern='integration|test'",
    "test:e2e": "playwright test",
    "test:api": "jest --testPathPattern=server",
    "test:frontend": "jest --testPathPattern=src",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "husky install"
  },
