# ===========================================
# SISPAT 2.0 - FRONTEND .env (DESENVOLVIMENTO)
# ===========================================
# Copie para .env (raiz) ao desenvolver localmente.

# URL da API backend (com /api no final)
VITE_API_URL=http://localhost:3000/api

# Usar backend real (true) ou mock (false)
VITE_USE_BACKEND=true

# Timeout em ms para requisições
VITE_API_TIMEOUT=30000

# Ambiente
VITE_ENV=development
VITE_APP_VERSION=2.1.0

# Error tracking (opcional, deixe vazio em dev)
VITE_SENTRY_DSN=
