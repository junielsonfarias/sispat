# =======================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# SISPAT - Sistema de Patrimônio
# =======================================

# ===== APLICAÇÃO =====
NODE_ENV=production
PORT=3000
VERSION=latest

# ===== BANCO DE DADOS =====
DATABASE_URL=postgresql://sispat_user:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/sispat_production
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ===== CACHE REDIS =====
REDIS_URL=redis://redis:6379/0

# ===== AUTENTICAÇÃO =====
NEXTAUTH_URL=https://sispat.exemplo.com
NEXTAUTH_SECRET=CHANGE_ME_STRONG_NEXTAUTH_SECRET_PRODUCTION

# ===== FEATURES =====
ENABLE_METRICS=true
ENABLE_CACHE=true
RUN_MIGRATIONS=true

# ===== LOGS =====
LOG_LEVEL=warn
LOG_FORMAT=json

# ===== MONITORAMENTO =====
HEALTH_CHECK_INTERVAL=15
GRAFANA_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD

# ===== BUILD INFO =====
BUILD_DATE=
VCS_REF=

# ===== DEPLOY CONFIG =====
SKIP_TESTS=false
BACKUP_DATABASE=true
CLEANUP_IMAGES=true

# ===== NOTIFICAÇÕES =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/PRODUCTION/WEBHOOK
ALERT_EMAIL=admin@exemplo.com

# ===== STORAGE =====
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# ===== RATE LIMITING =====
RATE_LIMIT_REQUESTS=500
RATE_LIMIT_WINDOW=3600

# ===== CORS =====
CORS_ORIGINS=https://sispat.exemplo.com

# ===== SECURITY =====
CSRF_SECRET=CHANGE_ME_STRONG_CSRF_SECRET_PRODUCTION
ENCRYPTION_KEY=CHANGE_ME_STRONG_ENCRYPTION_KEY_PRODUCTION

# ===== EMAIL =====
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=sispat@exemplo.com
SMTP_PASSWORD=CHANGE_ME_STRONG_SMTP_PASSWORD
SMTP_FROM=SISPAT <sispat@exemplo.com>

# ===== EXTERNAL APIs =====
API_TIMEOUT=30000
API_RETRIES=3

# ===== PERFORMANCE =====
NODE_OPTIONS=--max-old-space-size=2048

# ===== BACKUP =====
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION=7
BACKUP_S3_BUCKET=sispat-backups-production
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_KEY
AWS_REGION=us-east-1

# ===== MONITORING =====
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
LOKI_ENABLED=true

# ===== SSL/TLS =====
SSL_CERT_EMAIL=admin@exemplo.com
SSL_PROVIDER=letsencrypt

# ===== CDN =====
CDN_URL=https://cdn.exemplo.com
STATIC_ASSETS_URL=https://assets.exemplo.com
