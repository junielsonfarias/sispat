# =======================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# SISPAT - Sistema de Patrimônio
# =======================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.production
# 2. Substitua todos os valores CHANGE_ME_* por valores reais
# 3. Configure as URLs e domínios para seu ambiente de produção
# 4. Gere senhas seguras para todas as variáveis de segurança
# 5. Configure as credenciais AWS para backup

# ===== APLICAÇÃO =====
NODE_ENV=production
PORT=3000
VERSION=latest

# ===== BANCO DE DADOS =====
# Configure a URL do banco PostgreSQL de produção
DATABASE_URL=postgresql://sispat_user:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/sispat_production
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ===== CACHE REDIS =====
# URL do Redis para cache em produção
REDIS_URL=redis://redis:6379/0

# ===== AUTENTICAÇÃO =====
# URL base da aplicação de produção (substitua pelo seu domínio)
NEXTAUTH_URL=https://sispat.exemplo.com
# Gere uma chave secreta forte: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_STRONG_NEXTAUTH_SECRET_PRODUCTION

# ===== FEATURES =====
ENABLE_METRICS=true
ENABLE_CACHE=true
RUN_MIGRATIONS=true

# ===== LOGS =====
LOG_LEVEL=warn
LOG_FORMAT=json

# ===== MONITORAMENTO =====
HEALTH_CHECK_INTERVAL=15
# Senha para acesso ao Grafana em produção
GRAFANA_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD

# ===== BUILD INFO =====
# Serão preenchidas automaticamente pelo CI/CD
BUILD_DATE=
VCS_REF=

# ===== DEPLOY CONFIG =====
SKIP_TESTS=false
BACKUP_DATABASE=true
CLEANUP_IMAGES=true

# ===== NOTIFICAÇÕES =====
# Configure o webhook do Slack para notificações de produção
# Formato: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_WEBHOOK_URL=CHANGE_ME_SLACK_WEBHOOK_URL_PRODUCTION
# Email para alertas críticos
ALERT_EMAIL=admin@exemplo.com

# ===== STORAGE =====
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# ===== RATE LIMITING =====
RATE_LIMIT_REQUESTS=500
RATE_LIMIT_WINDOW=3600

# ===== CORS =====
# Domínios permitidos para CORS em produção
CORS_ORIGINS=https://sispat.exemplo.com

# ===== SECURITY =====
# Gere chaves secretas fortes para segurança em produção
# openssl rand -base64 32
CSRF_SECRET=CHANGE_ME_STRONG_CSRF_SECRET_PRODUCTION
ENCRYPTION_KEY=CHANGE_ME_STRONG_ENCRYPTION_KEY_PRODUCTION

# ===== EMAIL =====
# Configure o servidor SMTP para envio de emails em produção
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=sispat@exemplo.com
SMTP_PASSWORD=CHANGE_ME_STRONG_SMTP_PASSWORD
SMTP_FROM=SISPAT <sispat@exemplo.com>

# ===== EXTERNAL APIs =====
API_TIMEOUT=30000
API_RETRIES=3

# ===== PERFORMANCE =====
NODE_OPTIONS=--max-old-space-size=2048

# ===== BACKUP =====
# Configuração de backup automático para S3
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION=7
BACKUP_S3_BUCKET=sispat-backups-production
# Configure as credenciais AWS para backup
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_KEY
AWS_REGION=us-east-1

# ===== MONITORING =====
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
LOKI_ENABLED=true

# ===== SSL/TLS =====
# Email para certificados SSL
SSL_CERT_EMAIL=admin@exemplo.com
SSL_PROVIDER=letsencrypt

# ===== CDN =====
# URLs para CDN e assets estáticos
CDN_URL=https://cdn.exemplo.com
STATIC_ASSETS_URL=https://assets.exemplo.com
