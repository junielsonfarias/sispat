# =============================================================================
# CONFIGURAÇÃO DE PRODUÇÃO - SISPAT
# =============================================================================
# IMPORTANTE: Este arquivo contém configurações para ambiente de produção
# Copie este arquivo para .env e ajuste as configurações conforme necessário
# NUNCA commite o arquivo .env com dados reais!

# =============================================================================
# CONFIGURAÇÃO DO BANCO DE DADOS
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sispat_production
DB_USER=sispat_user
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DB_MAX_CONNECTIONS=50
DB_IDLE_TIMEOUT=60000
DB_CONNECTION_TIMEOUT=30000

# SSL Configuration (para produção com SSL)
DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=/path/to/ca-cert.pem
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem

# =============================================================================
# CONFIGURAÇÃO JWT (CRÍTICO PARA SEGURANÇA)
# =============================================================================
# IMPORTANTE: Gere uma chave segura usando:
# JWT_SECRET=$(openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_JWT_SECRET_MINIMUM_64_CHARS
JWT_EXPIRES_IN=8h

# =============================================================================
# CONFIGURAÇÃO DO SERVIDOR
# =============================================================================
PORT=3001
NODE_ENV=production

# URLs do Frontend (para CORS)
VITE_BACKEND_URL=https://yourdomain.com
VITE_API_URL=https://yourdomain.com/api
VITE_DOMAIN=https://yourdomain.com

# =============================================================================
# CONFIGURAÇÃO DE EMAIL (para reset de senha)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false

# =============================================================================
# CONFIGURAÇÃO DE UPLOAD DE ARQUIVOS
# =============================================================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# =============================================================================
# CONFIGURAÇÃO DE RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WHITELIST_IPS=127.0.0.1,::1

# =============================================================================
# CONFIGURAÇÃO CORS (CRÍTICO PARA SEGURANÇA)
# =============================================================================
# IMPORTANTE: Configure apenas os domínios que devem ter acesso
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# CONFIGURAÇÃO DE SEGURANÇA
# =============================================================================
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=1800000
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=1800000

# =============================================================================
# CONFIGURAÇÃO DE LOGGING
# =============================================================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
LOG_FILE_PATH=./logs

# =============================================================================
# CONFIGURAÇÃO DE BACKUP
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# =============================================================================
# CONFIGURAÇÃO DE REDIS (OPCIONAL - para cache e rate limiting)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# =============================================================================
# CONFIGURAÇÃO DE MONITORAMENTO
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090

# =============================================================================
# CONFIGURAÇÃO DE DESENVOLVIMENTO (DESABILITAR EM PRODUÇÃO)
# =============================================================================
DISABLE_DATABASE=false
ENABLE_DEBUG_ENDPOINTS=false