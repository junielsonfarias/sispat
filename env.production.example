# =======================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# SISPAT - Sistema de Patrimônio
# =======================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.production
# 2. Substitua todos os valores CHANGE_ME_* por valores reais
# 3. Configure as URLs e domínios para seu ambiente de produção
# 4. Gere senhas seguras para todas as variáveis de segurança
# 5. Configure as credenciais AWS para backup

# Configurações do Servidor
PORT=3001
HOST=0.0.0.0

# Configurações do Frontend (Vite)
VITE_PORT=8080
VITE_API_TARGET=http://localhost:3001
VITE_API_URL=http://localhost:3001/api
VITE_APP_NAME=SISPAT
VITE_APP_VERSION=1.0.0

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sispat_production
DB_USER=sispat_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_2025
DATABASE_URL=postgresql://sispat_user:CHANGE_ME_STRONG_DB_PASSWORD_2025@localhost:5432/sispat_production
DB_MAX_CONNECTIONS=100
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD_2025
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD_2025@localhost:6379

# JWT e Segurança
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_2025_MIN_32_CHARS_LONG
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Senhas Padrão (ALTERE EM PRODUÇÃO)
DEFAULT_SUPERUSER_PASSWORD=CHANGE_ME_STRONG_SUPERUSER_PASSWORD_2025
TEST_PASSWORD=CHANGE_ME_STRONG_TEST_PASSWORD_2025

# CORS
CORS_ORIGIN=https://sispat.vps-kinghost.net,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
CORS_CREDENTIALS=true

# Logs
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# IMPORTANTE: NÃO definir NODE_ENV aqui - o Vite gerencia automaticamente
# NODE_ENV=production  # ← REMOVER ESTA LINHA

# ===== FEATURES =====
ENABLE_METRICS=true
ENABLE_CACHE=true
RUN_MIGRATIONS=true

# ===== LOGS =====
LOG_LEVEL=warn
LOG_FORMAT=json

# ===== MONITORAMENTO =====
HEALTH_CHECK_INTERVAL=15
# Senha para acesso ao Grafana em produção
GRAFANA_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD

# ===== BUILD INFO =====
# Serão preenchidas automaticamente pelo CI/CD
BUILD_DATE=
VCS_REF=

# ===== DEPLOY CONFIG =====
SKIP_TESTS=false
BACKUP_DATABASE=true
CLEANUP_IMAGES=true

# ===== NOTIFICAÇÕES =====
# Configure o webhook do Slack para notificações de produção
# Formato: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_WEBHOOK_URL=CHANGE_ME_SLACK_WEBHOOK_URL_PRODUCTION
# Email para alertas críticos
ALERT_EMAIL=admin@exemplo.com

# ===== STORAGE =====
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# ===== RATE LIMITING =====
RATE_LIMIT_REQUESTS=500
RATE_LIMIT_WINDOW=3600

# ===== CORS =====
# Domínios permitidos para CORS em produção
CORS_ORIGINS=https://sispat.exemplo.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
ALLOWED_ORIGINS=https://sispat.exemplo.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# ===== SECURITY =====
# Gere chaves secretas fortes para segurança em produção
# openssl rand -base64 32
CSRF_SECRET=CHANGE_ME_STRONG_CSRF_SECRET_PRODUCTION
ENCRYPTION_KEY=CHANGE_ME_STRONG_ENCRYPTION_KEY_PRODUCTION

# ===== EMAIL =====
# Configure o servidor SMTP para envio de emails em produção
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=sispat@exemplo.com
SMTP_PASSWORD=CHANGE_ME_STRONG_SMTP_PASSWORD
SMTP_FROM=SISPAT <sispat@exemplo.com>

# ===== EXTERNAL APIs =====
API_TIMEOUT=30000
API_RETRIES=3

# ===== PERFORMANCE =====
NODE_OPTIONS=--max-old-space-size=2048

# ===== BACKUP =====
# Configuração de backup automático para S3
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION=7
BACKUP_S3_BUCKET=sispat-backups-production
# Configure as credenciais AWS para backup
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_KEY
AWS_REGION=us-east-1

# ===== MONITORING =====
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
LOKI_ENABLED=true

# ===== SSL/TLS =====
# Email para certificados SSL
SSL_CERT_EMAIL=admin@exemplo.com
SSL_PROVIDER=letsencrypt

# ===== CDN =====
# URLs para CDN e assets estáticos
CDN_URL=https://cdn.exemplo.com
STATIC_ASSETS_URL=https://assets.exemplo.com
