# ===========================================================================
# SISPAT 2.0 — Variáveis para o docker-compose.prod.yml
# ===========================================================================
# Como usar (teste local ou deploy via Docker):
#   1) Copie:   cp .env.docker.example .env
#   2) Gere segredos fortes (comandos abaixo) e cole nos campos.
#   3) Suba:    docker compose -f docker-compose.prod.yml up -d --build
#   4) Acesse:  http://localhost      (Nginx na porta 80)
#
# ⚠️  NUNCA versione o .env preenchido. NUNCA use estes valores de exemplo.
#
# Gerar segredos (rode e cole a saída):
#   DB_PASSWORD     →  openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | cut -c1-32
#   REDIS_PASSWORD  →  openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | cut -c1-32
#   JWT_SECRET      →  openssl rand -hex 64
# ===========================================================================

# Senha do PostgreSQL (usuário sispat_user / banco sispat_prod).
# Use só letras/números (a senha entra na DATABASE_URL — evite / + = @ : que
# quebram a URL). NÃO use "password"/"postgres"/"123456": o backend recusa senha
# insegura em produção (validate-env).
DB_PASSWORD=TROQUE_por_senha_forte_alfanumerica

# Senha do Redis (cache + rate limit distribuído).
REDIS_PASSWORD=TROQUE_por_senha_forte_alfanumerica

# Segredo do JWT — mínimo 32 chars (use openssl rand -hex 64 = 128 chars).
# NÃO pode conter: dev, test, example, default, secret, CHANGE_THIS.
JWT_SECRET=TROQUE_por_openssl_rand_hex_64

# URL pública do frontend (vira a origem permitida no CORS do backend).
#   Teste local:  http://localhost
#   Produção:     https://seu-dominio.com.br
FRONTEND_URL=http://localhost

# URL da API embutida no bundle do frontend (build ARG do Dockerfile).
#   Teste local:  deixe EM BRANCO/comentado → usa o default http://localhost:3000/api
#   Produção:     VITE_API_URL=https://seu-dominio.com.br/api
# Importante: é build-time. Se mudar, refaça o build: docker compose ... up -d --build
# VITE_API_URL=https://seu-dominio.com.br/api
