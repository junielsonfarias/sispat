# ===========================================
# SISPAT 2.0 - Backend (.env de exemplo)
# ===========================================
# Copie para .env e ajuste os valores.
# Variaveis OBRIGATORIAS: DATABASE_URL, JWT_SECRET, NODE_ENV.
# Em producao (NODE_ENV=production) ha validacoes extras em
# src/config/validate-env.ts (JWT forte, senha de banco, SSL remoto, etc).

# Server
NODE_ENV=development
PORT=3000
HOST=localhost

# Database
DATABASE_URL=postgresql://user:strongpassword@localhost:5432/sispat_db?schema=public

# JWT
# IMPORTANTE: gere um valor aleatorio forte com `openssl rand -hex 64`.
# Em producao NAO use palavras como "secret", "dev", "test", "example",
# "default" ou "CHANGE_THIS" (validate-env.ts rejeita o boot).
JWT_SECRET=COLE_AQUI_UM_VALOR_ALEATORIO_DE_64_BYTES
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:8080

# Seguranca
BCRYPT_ROUNDS=12
MAX_REQUEST_SIZE=10mb

# Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Logs
LOG_LEVEL=info

# ===========================================
# OPCIONAIS
# ===========================================

# Redis (cache + rate limit distribuido) - descomente para ativar
# ENABLE_REDIS=true
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Email/SMTP (necessario para reset de senha) - opcional
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="SISPAT <noreply@exemplo.com>"

# Observabilidade - opcional
# SENTRY_DSN=
# ENABLE_METRICS=true
# ENABLE_HEALTH_MONITOR=true

# Frontend (apenas se buildar o frontend a partir daqui) - opcional
# VITE_API_URL=http://localhost:3000/api
