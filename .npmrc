# Configurações NPM para SISPAT
# Evitar warnings de configurações específicas do pnpm

# Configurações de cache
cache-max=10000000000
cache-min=86400

# Configurações de instalação
prefer-offline=true
audit-level=moderate
fund=false

# Configurações de logs
loglevel=warn
progress=true

# Configurações de segurança
audit-level=moderate