shamefully-hoist=true
store-dir=${PODS_MANAGER_ROOT:-/app/cache}/.pnpm/store
cache-dir=${PODS_MANAGER_ROOT:-/app/cache}/.pnpm/cache
color=auto
loglevel=info
package-manager=pnpm@latest
# Não rodar `pnpm install` automaticamente antes de cada `pnpm run <script>`.
# Sem isso, o gate de build scripts não aprovados (core-js/esbuild) aborta
# qualquer script (ex.: dev:all) com ERR_PNPM_IGNORED_BUILDS.
verify-deps-before-run=false
