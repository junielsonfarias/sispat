# =======================================
# VARIÁVEIS DE AMBIENTE - STAGING
# SISPAT - Sistema de Patrimônio
# =======================================

# ===== APLICAÇÃO =====
NODE_ENV=production
PORT=3000
VERSION=staging

# ===== BANCO DE DADOS =====
DATABASE_URL=postgresql://sispat_user:CHANGE_ME_DB_PASSWORD@postgres:5432/sispat_staging
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ===== CACHE REDIS =====
REDIS_URL=redis://redis:6379/0

# ===== AUTENTICAÇÃO =====
NEXTAUTH_URL=https://sispat-staging.exemplo.com
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET_STAGING

# ===== FEATURES =====
ENABLE_METRICS=true
ENABLE_CACHE=true
RUN_MIGRATIONS=true

# ===== LOGS =====
LOG_LEVEL=info
LOG_FORMAT=json

# ===== MONITORAMENTO =====
HEALTH_CHECK_INTERVAL=30
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ===== BUILD INFO =====
BUILD_DATE=
VCS_REF=

# ===== DEPLOY CONFIG =====
SKIP_TESTS=false
BACKUP_DATABASE=true
CLEANUP_IMAGES=false

# ===== NOTIFICAÇÕES =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ===== STORAGE =====
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# ===== RATE LIMITING =====
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# ===== CORS =====
CORS_ORIGINS=https://sispat-staging.exemplo.com

# ===== SECURITY =====
CSRF_SECRET=CHANGE_ME_CSRF_SECRET_STAGING
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_STAGING

# ===== EMAIL (Opcional) =====
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=sispat@exemplo.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=SISPAT Staging <sispat@exemplo.com>

# ===== EXTERNAL APIs (Opcional) =====
API_TIMEOUT=30000
API_RETRIES=3
