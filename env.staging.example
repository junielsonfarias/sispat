# =======================================
# VARIÁVEIS DE AMBIENTE - STAGING
# SISPAT - Sistema de Patrimônio
# =======================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.staging
# 2. Substitua todos os valores CHANGE_ME_* por valores reais
# 3. Configure as URLs e domínios para seu ambiente
# 4. Gere senhas seguras para todas as variáveis de segurança

# ===== APLICAÇÃO =====
NODE_ENV=production
PORT=3000
VERSION=staging

# ===== BANCO DE DADOS =====
# Configure a URL do banco PostgreSQL
DATABASE_URL=postgresql://sispat_user:CHANGE_ME_DB_PASSWORD@postgres:5432/sispat_staging
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ===== CACHE REDIS =====
# URL do Redis para cache
REDIS_URL=redis://redis:6379/0

# ===== AUTENTICAÇÃO =====
# URL base da aplicação (substitua pelo seu domínio)
NEXTAUTH_URL=https://sispat-staging.exemplo.com
# Gere uma chave secreta forte: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET_STAGING

# ===== FEATURES =====
ENABLE_METRICS=true
ENABLE_CACHE=true
RUN_MIGRATIONS=true

# ===== LOGS =====
LOG_LEVEL=info
LOG_FORMAT=json

# ===== MONITORAMENTO =====
HEALTH_CHECK_INTERVAL=30
# Senha para acesso ao Grafana
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ===== BUILD INFO =====
# Serão preenchidas automaticamente pelo CI/CD
BUILD_DATE=
VCS_REF=

# ===== DEPLOY CONFIG =====
SKIP_TESTS=false
BACKUP_DATABASE=true
CLEANUP_IMAGES=false

# ===== NOTIFICAÇÕES =====
# Configure o webhook do Slack para notificações
# Formato: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_WEBHOOK_URL=CHANGE_ME_SLACK_WEBHOOK_URL

# ===== STORAGE =====
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# ===== RATE LIMITING =====
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# ===== CORS =====
# Domínios permitidos para CORS (substitua pelo seu domínio)
CORS_ORIGINS=https://sispat-staging.exemplo.com

# ===== SECURITY =====
# Gere chaves secretas fortes para segurança
# openssl rand -base64 32
CSRF_SECRET=CHANGE_ME_CSRF_SECRET_STAGING
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_STAGING

# ===== EMAIL (Opcional) =====
# Configure o servidor SMTP para envio de emails
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=sispat@exemplo.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=SISPAT Staging <sispat@exemplo.com>

# ===== EXTERNAL APIs (Opcional) =====
API_TIMEOUT=30000
API_RETRIES=3
